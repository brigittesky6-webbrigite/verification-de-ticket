# ============================================================
#  TicketCheck — Configuration environnement
#  Copiez ce fichier en .env et remplissez les valeurs
#  Sur Render : ajoutez ces variables dans Environment > Add Variable
# ============================================================

PORT=3000
NODE_ENV=production

# ─── URL publique ────────────────────────────────────────────
# Sur Render : https://votre-app.onrender.com
APP_URL=https://votre-app.onrender.com

# ─── Email administrateur ────────────────────────────────────
ADMIN_EMAIL=votre-email@gmail.com

# ─── SMTP (Gmail recommandé) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=TicketCheck
SMTP_FROM_EMAIL=votre-email@gmail.com

# ─── Sécurité ────────────────────────────────────────────────
ADMIN_SECRET=changez-cette-cle-secrete-tres-longue

# ─── SQLite ──────────────────────────────────────────────────
# Sur Render Free : les données sont perdues au redémarrage
# Pour les conserver, activez un Render Disk monté sur /data
DB_PATH=/data/tickets.db

# ─── Cloudinary (images — GRATUIT 25 Go) ─────────────────────
# 1. Créez un compte sur https://cloudinary.com (gratuit)
# 2. Tableau de bord → copiez Cloud Name, API Key, API Secret
# Si vous ne souhaitez pas utiliser Cloudinary, laissez ces valeurs vides.
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=votre-api-secret-cloudinary

# ─── Upload ──────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOADS_PATH=/data/uploads
